---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const {
  title = 'Cibele Plastic — Bioplástico que não custa o planeta',
  description = 'Cibele Plastic: soluções em bioplástico sustentável para embalagens, construção civil e produtos médicos. Menos plástico fóssil, o mesmo desempenho.',
  active = '',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8f3e6" />
    <meta name="color-scheme" content="light dark" />
    <!-- Bloqueia extensões de modo escuro (Dark Reader e derivadas):
         o site tem tema escuro próprio, então dispensa a injeção externa. -->
    <meta name="darkreader-lock" />
    <link rel="icon" type="image/png" href="/img/faviconum.png" />
    <title>{title}</title>

    <!-- Aplica o tema salvo ANTES da pintura, evitando flash de cor. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('cibele-theme');
          var theme =
            stored === 'dark' || stored === 'light'
              ? stored
              : window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.setAttribute('data-theme', theme);
          var meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0e1410' : '#f8f3e6');
        } catch (e) {}
      })();
    </script>

    <!-- Ubuntu — fonte única do site (texto e títulos) via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!reduce) document.documentElement.classList.add('is-animate');
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#conteudo">Pular para o conteúdo</a>
    <Header active={active} />
    <main id="conteudo">
      <slot />
    </main>
    <Footer />
    <CookieConsent />

    <script>
      import '../scripts/animations.ts';
    </script>
  </body>
</html>
