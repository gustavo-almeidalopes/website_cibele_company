---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    nome: 'Gustavo Lopes',
    rgm: '3XX83XX8',
    papel: 'Front-end & Back-end',
    bio: 'Responsável pelas páginas de produtos, carrinho e pela nova camada de front-end em Astro.',
    img: 'gustavo.jpg',
  },
  {
    nome: 'Matheus Souza',
    rgm: '3XX14XX3',
    papel: 'Back-end & QA',
    bio: 'Atuação em back-end, revisão de código e consistência visual entre as páginas.',
    img: 'matheus.webp',
  },
];

const values = [
  { t: 'Origem renovável', d: 'Priorizamos matérias-primas de fontes vegetais em vez de petróleo.' },
  { t: 'Ciclo curto', d: 'Produtos pensados para se decompor rapidamente após o uso.' },
  { t: 'Transparência', d: 'Clareza sobre composição e impacto de cada item do catálogo.' },
];
---

<BaseLayout
  active="sobre"
  title="Sobre — Cibele Plastic"
  description="A história e a equipe por trás da Cibele Plastic, projeto acadêmico de e-commerce de bioplásticos sustentáveis."
>
  <section class="phero" data-hero>
    <div class="container-wide">
      <p class="eyebrow" data-hero-item>Sobre nós</p>
      <h1 class="display phero__title">
        <span class="line-mask"><span class="line-inner">Bioplástico com</span></span>
        <span class="line-mask"><span class="line-inner">propósito.</span></span>
      </h1>
      <p class="lead phero__lead" data-hero-item>
        A Cibele Plastic nasceu como um projeto acadêmico com uma ambição simples: mostrar que é
        possível ter o desempenho do plástico convencional sem o peso ambiental do plástico fóssil.
      </p>
    </div>
  </section>

  <section class="section story paper">
    <div class="container">
      <div class="story__grid">
        <p class="eyebrow" data-reveal="fade">(A história)</p>
        <div class="story__body">
          <h2 class="h-md story__title" data-lines>
            <span class="line-mask"><span class="line-inner">Do laboratório ao</span></span>
            <span class="line-mask"><span class="line-inner">dia a dia das pessoas.</span></span>
          </h2>
          <p data-reveal="up">
            Reunimos embalagens, materiais de construção e produtos médicos sob um mesmo princípio:
            substituir o plástico de origem fóssil por bioplásticos de fontes renováveis. Cada
            categoria foi desenhada para provar que sustentabilidade e qualidade caminham juntas.
          </p>
          <p data-reveal="up">
            Este site é a vitrine desse conceito — agora com um front-end moderno em Astro e
            animações em Anime.js, mantendo a base em PHP para o fluxo de compra.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section values">
    <div class="container-wide">
      <div class="values__grid" data-reveal-group>
        {
          values.map((v, i) => (
            <div class="value" data-reveal-item>
              <span class="value__num">0{i + 1}</span>
              <h3 class="value__title">{v.t}</h3>
              <p class="text-muted">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section team">
    <div class="container-wide">
      <header class="team__header">
        <p class="eyebrow" data-reveal="fade">A equipe</p>
        <h2 class="h-xl" data-lines>
          <span class="line-mask"><span class="line-inner">Quem faz</span></span>
        </h2>
      </header>

      <div class="team__grid" data-reveal-group>
        {
          team.map((member) => (
            <article class="member" data-reveal-item data-cursor>
              <div class="member__photo">
                <img src={`/img/${member.img}`} alt={member.nome} loading="lazy" width="600" height="720" />
                <span class="member__role">{member.papel}</span>
              </div>
              <div class="member__info">
                <h3 class="member__name">{member.nome}</h3>
                <p class="member__rgm">RGM {member.rgm}</p>
                <p class="member__bio text-muted">{member.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    padding-block: clamp(9rem, 16vw, 14rem) clamp(2rem, 5vw, 4rem);
  }

  .phero .eyebrow {
    margin-bottom: 1.5rem;
  }

  .phero__title {
    margin-bottom: 2rem;
  }

  .phero__lead {
    max-width: 56ch;
    color: var(--muted);
  }

  .story__grid {
    display: grid;
    gap: 2rem;
  }

  .story__body {
    display: grid;
    gap: 1.4rem;
    max-width: 60ch;
  }

  .story__title {
    margin-bottom: 0.6rem;
  }

  .story__body p {
    color: var(--muted-light);
    font-size: var(--step-1);
    line-height: 1.5;
  }

  @media (min-width: 900px) {
    .story__grid {
      grid-template-columns: 0.5fr 1.5fr;
      gap: 4rem;
    }
  }

  .values__grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1fr;
  }

  .value {
    padding: 2rem 1.8rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--ink-2);
    transition: border-color 0.4s var(--ease), transform 0.4s var(--ease);
  }

  .value:hover {
    border-color: rgba(23, 51, 23, 0.4);
    transform: translateY(-5px);
  }

  .value__num {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 1.4rem;
  }

  .value__title {
    font-size: 1.3rem;
    margin-bottom: 0.6rem;
  }

  @media (min-width: 760px) {
    .values__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team__header {
    margin-bottom: 2.5rem;
  }

  .team__header .eyebrow {
    margin-bottom: 1rem;
  }

  .team__grid {
    display: grid;
    gap: 1.6rem;
    grid-template-columns: 1fr;
  }

  .member {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--ink-2);
    transition: transform 0.5s var(--ease), border-color 0.5s var(--ease);
  }

  .member:hover {
    transform: translateY(-6px);
    border-color: rgba(23, 51, 23, 0.4);
  }

  .member__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .member__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
    transition: filter 0.6s var(--ease), transform 0.7s var(--ease);
  }

  .member:hover .member__photo img {
    filter: grayscale(0);
    transform: scale(1.05);
  }

  .member__role {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: var(--forest);
    border: 1px solid var(--forest);
    backdrop-filter: blur(6px);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mint);
  }

  .member__info {
    padding: 1.6rem;
  }

  .member__name {
    font-size: 1.5rem;
    margin-bottom: 0.3rem;
  }

  .member__rgm {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.9rem;
  }

  .member__bio {
    font-size: 0.92rem;
    max-width: 46ch;
  }

  @media (min-width: 720px) {
    .team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
