---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    nome: 'Gustavo Lopes',
    rgm: '3XX83XX8',
    papel: 'Front-end & Back-end',
    bio: 'Responsável pelas páginas de produtos, carrinho e pela camada de front-end em Astro.',
    img: 'gustavo.jpg',
  },
  {
    nome: 'Matheus Souza',
    rgm: '3XX14XX3',
    papel: 'Back-end & QA',
    bio: 'Atuação em back-end, revisão de código e consistência visual entre as páginas.',
    img: 'matheus.webp',
  },
];

const values = [
  {
    t: 'Origem renovável',
    d: 'Priorizamos matérias-primas de fontes vegetais em vez de petróleo, em todas as linhas.',
  },
  {
    t: 'Ciclo curto',
    d: 'Produtos pensados para se decompor rapidamente depois de cumprir o seu papel.',
  },
  {
    t: 'Transparência',
    d: 'Clareza sobre a composição e o impacto de cada item do catálogo, sem letras miúdas.',
  },
];
---

<BaseLayout
  active="sobre"
  title="Sobre — Cibele"
  description="A história e a equipe por trás da Cibele, projeto de bioplásticos sustentáveis de origem vegetal."
>
  <section class="phero">
    <div class="container">
      <p class="eyebrow phero__eyebrow" data-reveal="fade">Sobre</p>
      <h1 class="display phero__title" data-reveal>
        Bioplástico<br />
        <em class="serif-italic">com propósito.</em>
      </h1>
      <p class="lead phero__lead text-muted" data-reveal>
        A Cibele nasceu de uma ambição simples: provar que é possível ter o desempenho do plástico
        convencional sem o peso ambiental do plástico fóssil.
      </p>
    </div>
  </section>

  <!-- A HISTÓRIA -->
  <section class="section night story">
    <div class="container story__grid">
      <p class="meta" data-reveal="fade">01 — A história</p>
      <div class="story__body">
        <h2 class="h-lg story__title" data-reveal>
          Do laboratório ao <em class="serif-italic">dia a dia das pessoas.</em>
        </h2>
        <p data-reveal>
          Reunimos embalagens, materiais de construção e produtos médicos sob um mesmo princípio:
          substituir o plástico de origem fóssil por bioplásticos de fontes renováveis. Cada
          categoria foi desenhada para provar que sustentabilidade e qualidade caminham juntas.
        </p>
        <p data-reveal>
          Este site é a vitrine desse conceito — um front-end leve em Astro, desenhado com o mesmo
          cuidado que dedicamos a cada material do catálogo.
        </p>
      </div>
    </div>
  </section>

  <!-- OS VALORES -->
  <section class="section values">
    <div class="container">
      <p class="meta values__marker" data-reveal="fade">02 — Os valores</p>
      <div class="values__grid" data-reveal-group>
        {
          values.map((v, i) => (
            <div class="value" data-reveal>
              <span class="value__num" aria-hidden="true">0{i + 1}</span>
              <h3 class="value__title">{v.t}</h3>
              <p class="value__text text-muted">{v.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- A EQUIPE -->
  <section class="section team">
    <div class="container">
      <header class="team__header">
        <p class="meta" data-reveal="fade">03 — A equipe</p>
        <h2 class="h-xl" data-reveal>Quem faz</h2>
      </header>

      <div class="team__grid" data-reveal-group>
        {
          team.map((member) => (
            <article class="member" data-reveal>
              <figure class="member__photo">
                <img
                  src={`/img/${member.img}`}
                  alt={`Retrato de ${member.nome}`}
                  loading="lazy"
                  width="600"
                  height="720"
                />
              </figure>
              <div class="member__info">
                <h3 class="member__name">{member.nome}</h3>
                <p class="member__role meta">{member.papel} · RGM {member.rgm}</p>
                <p class="member__bio text-muted">{member.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    padding-block: clamp(9.5rem, 16vw, 14rem) clamp(3.5rem, 7vw, 6rem);
  }

  .phero__eyebrow {
    margin-bottom: 2rem;
  }

  .phero__title {
    margin-bottom: 2.2rem;
  }

  .phero__lead {
    max-width: 54ch;
  }

  /* A HISTÓRIA */
  .story__grid {
    display: grid;
    gap: 2.5rem;
  }

  .story__body {
    display: grid;
    gap: 1.6rem;
    max-width: 62ch;
  }

  .story__title {
    margin-bottom: 0.8rem;
  }

  .story__body p {
    color: var(--ivory-2);
    font-size: var(--step-1);
    line-height: 1.6;
  }

  @media (min-width: 900px) {
    .story__grid {
      grid-template-columns: 1fr 3fr;
      gap: 2rem;
    }
  }

  /* OS VALORES */
  .values__marker {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .values__grid {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .value {
    padding: 2.2rem 0;
    border-bottom: 1px solid var(--line);
  }

  .value__num {
    display: block;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink-3);
    margin-bottom: 1.6rem;
  }

  .value__title {
    font-size: 1.4rem;
    font-weight: 400;
    margin-bottom: 0.7rem;
  }

  .value__text {
    max-width: 36ch;
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (min-width: 760px) {
    .values__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 0 3rem;
    }
  }

  /* A EQUIPE */
  .team {
    padding-top: 0;
  }

  .team__header {
    display: grid;
    gap: 1.2rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .team__grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
  }

  .member__photo {
    aspect-ratio: 5 / 6;
    background: var(--stone);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .member__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.02);
    transition:
      filter 0.8s var(--ease),
      transform 1s var(--ease);
  }

  .member:hover .member__photo img {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  .member__name {
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .member__role {
    margin-bottom: 1rem;
  }

  .member__bio {
    font-size: 0.92rem;
    line-height: 1.65;
    max-width: 44ch;
  }

  @media (min-width: 720px) {
    .team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
