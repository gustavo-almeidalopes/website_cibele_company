---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { collections, products } from '../data/catalog';

const prices = products.map((p) => p.preco);
const minPrice = Math.min(...prices);
const maxPrice = Math.max(...prices);
---

<BaseLayout
  active="embalagens"
  title="Embalagens sustentáveis — Cibele Plastic"
  description="Catálogo de embalagens em bioplástico da Cibele Plastic: mesa, bebidas e delivery. O desempenho do plástico convencional, sem a herança fóssil."
>
  <div class="container chero">
    <nav class="breadcrumb" aria-label="Trilha">
      <a href="/">Início</a>
      <span class="breadcrumb__sep" aria-hidden="true">/</span>
      <span class="breadcrumb__current">Embalagens</span>
    </nav>

    <h1 class="chero__title">Embalagens</h1>
    <p class="lead chero__desc">
      Uma linha completa de embalagens descartáveis feitas de fontes renováveis — para food
      service, eventos, cafeterias e delivery.
    </p>
  </div>

  <div class="container plp" data-plp>
    <div class="plp__toolbar">
      <p class="plp__count" data-plp-count>{products.length} produtos</p>
      <div class="plp__sort">
        <label for="ordenar">Ordenar por</label>
        <select id="ordenar" data-sort-select>
          <option value="relevancia">Relevância</option>
          <option value="menor-preco">Menor preço</option>
          <option value="maior-preco">Maior preço</option>
          <option value="nome">Nome (A-Z)</option>
        </select>
      </div>
    </div>

    <div class="plp__body">
      <aside class="filters">
        <div class="filters__group">
          <p class="filters__title">Coleção</p>
          {
            collections.map((col) => (
              <label class="filters__option">
                <input type="checkbox" value={col.slug} data-filter-collection />
                {col.titulo}
              </label>
            ))
          }
        </div>

        <div class="filters__group">
          <p class="filters__title">Preço</p>
          <div class="filters__price">
            <input
              type="number"
              inputmode="decimal"
              placeholder={`Mín. ${minPrice.toFixed(0)}`}
              min={minPrice}
              max={maxPrice}
              data-filter-price-min
              aria-label="Preço mínimo, em reais"
            />
            <span aria-hidden="true">–</span>
            <input
              type="number"
              inputmode="decimal"
              placeholder={`Máx. ${maxPrice.toFixed(0)}`}
              min={minPrice}
              max={maxPrice}
              data-filter-price-max
              aria-label="Preço máximo, em reais"
            />
          </div>
        </div>

        <button class="filters__clear" type="button" data-filter-clear>Limpar filtros</button>
      </aside>

      <div>
        <div class="plp__grid" data-plp-grid data-reveal-group>
          {products.map((product) => <ProductCard product={product} />)}
        </div>
        <p class="plp__empty" data-plp-empty>Nenhum produto encontrado com esses filtros.</p>
      </div>
    </div>
  </div>

  <section class="section-lg paper cta2">
    <div class="container cta2__inner">
      <p class="eyebrow" data-reveal="fade">Para empresas</p>
      <h2 class="h-xl cta2__title" data-lines>
        <span class="line-mask"><span class="line-inner">Um orçamento sob</span></span>
        <span class="line-mask"><span class="line-inner">medida para o seu <span class="text-accent">negócio</span>.</span></span>
      </h2>
      <a class="btn btn--primary" href="/contato" data-reveal="fade">
        <span>Solicitar orçamento</span>
        <svg class="arrow" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .chero {
    padding-block: clamp(2rem, 5vw, 3rem) 1.6rem;
    display: grid;
    gap: 1rem;
  }

  .chero__title {
    font-size: var(--step-4);
    line-height: 1.05;
  }

  .chero__desc {
    max-width: 60ch;
    color: var(--muted);
  }

  .plp {
    padding-block: 1rem var(--space-128);
  }
</style>
