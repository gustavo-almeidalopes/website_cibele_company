---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { categories, getFeaturedProducts, stats } from '../data/catalog';

const featured = getFeaturedProducts();

const principles = [
  {
    t: 'Matéria-prima renovável',
    d: 'Bioplásticos derivados de fontes vegetais, reduzindo a dependência do petróleo em cada peça produzida.',
  },
  {
    t: 'Decomposição acelerada',
    d: 'Produtos que retornam à natureza em uma fração do tempo do plástico convencional.',
  },
  {
    t: 'Desempenho comprovado',
    d: 'Resistência e segurança verificadas para o uso diário — na mesa, na obra e no hospital.',
  },
  {
    t: 'Cadeia consciente',
    d: 'Processos desenhados para gerar menos emissão de CO₂ em cada etapa, da origem à entrega.',
  },
];
---

<BaseLayout active="home">
  <!-- HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <p class="eyebrow hero__eyebrow" data-reveal="fade">Bioplásticos de origem vegetal</p>
      <h1 class="display hero__title" data-reveal>
        O desempenho do plástico.<br />
        <em class="serif-italic">Sem a herança fóssil.</em>
      </h1>
      <div class="hero__row" data-reveal>
        <p class="lead hero__lead text-muted">
          A Cibele desenvolve materiais para embalagens, construção civil e produtos médicos —
          concebidos a partir de fontes vegetais e desenhados para durar apenas o necessário.
        </p>
        <div class="hero__actions">
          <a class="btn btn--solid" href="/contato">Iniciar uma conversa</a>
          <a class="link-line" href="#segmentos">Conhecer os segmentos</a>
        </div>
      </div>
    </div>
    <div class="container hero__foot" data-reveal="fade">
      <hr class="hr" />
      <div class="hero__meta">
        <span class="meta">Cibele — Bioplásticos</span>
        <span class="meta">Embalagens · Construção · Saúde</span>
        <span class="meta">Brasil</span>
      </div>
    </div>
  </section>

  <!-- CAPÍTULO 01 — A MATÉRIA -->
  <section class="section intro">
    <div class="container intro__grid">
      <p class="meta intro__marker" data-reveal="fade">01 — A matéria</p>
      <div class="intro__body">
        <h2 class="h-lg intro__title" data-reveal>
          Trocamos o plástico fóssil por materiais de origem renovável,
          <em class="serif-italic">sem abrir mão de resistência.</em>
        </h2>
        <p class="intro__text text-muted" data-reveal>
          Cada item do nosso catálogo nasce de fontes vegetais e se decompõe muito mais rápido que
          o plástico tradicional. É tecnologia a serviço de um ciclo mais limpo — do laboratório à
          obra, da cozinha ao hospital.
        </p>
      </div>
    </div>
  </section>

  <!-- CAPÍTULO 02 — SEGMENTOS -->
  <section class="section segments" id="segmentos">
    <div class="container">
      <header class="segments__header">
        <p class="meta" data-reveal="fade">02 — Segmentos</p>
        <h2 class="h-xl" data-reveal>Três frentes, um propósito</h2>
      </header>

      <div class="segments__list">
        {
          categories.map((cat) => (
            <a class="segment" href={cat.path} data-reveal>
              <span class="segment__index" aria-hidden="true">{cat.indice}</span>
              <div class="segment__main">
                <h3 class="segment__title">{cat.titulo}</h3>
                <p class="segment__desc text-muted">{cat.resumo}</p>
              </div>
              <figure class="segment__media" aria-hidden="true">
                <img src={`/img/${cat.imagem}`} alt="" loading="lazy" width="220" height="220" />
              </figure>
              <span class="segment__cue" aria-hidden="true">Ver segmento</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FATOS — em silêncio, sem contadores -->
  <section class="section-sm facts">
    <div class="container">
      <dl class="facts__grid">
        {
          stats.map((stat) => (
            <div class="fact" data-reveal>
              <dd class="fact__num">
                {stat.prefixo}{stat.valor}{stat.sufixo}
              </dd>
              <dt class="fact__label text-muted">{stat.rotulo}</dt>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- CAPÍTULO 03 — O COMPROMISSO -->
  <section class="section night manifesto">
    <div class="container manifesto__grid">
      <div class="manifesto__intro">
        <p class="meta" data-reveal="fade">03 — O compromisso</p>
        <h2 class="h-lg" data-reveal>
          Menos resíduo.<br />
          <em class="serif-italic">Mais futuro.</em>
        </h2>
      </div>
      <ol class="manifesto__list">
        {
          principles.map((item, i) => (
            <li class="manifesto__item" data-reveal>
              <span class="manifesto__num" aria-hidden="true">0{i + 1}</span>
              <div>
                <h3 class="manifesto__title">{item.t}</h3>
                <p class="manifesto__text">{item.d}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- CAPÍTULO 04 — SELEÇÃO -->
  <section class="section featured">
    <div class="container">
      <header class="featured__header">
        <div>
          <p class="meta" data-reveal="fade">04 — Seleção</p>
          <h2 class="h-lg" data-reveal>Peças em destaque</h2>
        </div>
        <a class="link-line" href="/embalagens" data-reveal="fade">Ver catálogo</a>
      </header>

      <div class="featured__grid" data-reveal-group>
        {featured.map((product, i) => <ProductCard product={product} index={i} />)}
      </div>
    </div>
  </section>

  <!-- CONVITE -->
  <section class="section invite">
    <div class="container invite__inner">
      <p class="eyebrow" data-reveal="fade">Vamos juntos</p>
      <h2 class="h-xl invite__title" data-reveal>
        Construa um futuro mais limpo <em class="serif-italic">com a gente.</em>
      </h2>
      <div data-reveal>
        <a class="btn btn--solid" href="/contato">Solicitar orçamento</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* HERO */
  .hero {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 92svh;
    padding-top: 9rem;
  }

  .hero__eyebrow {
    margin-bottom: 2rem;
  }

  .hero__title {
    max-width: 14em;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .hero__row {
    display: grid;
    gap: 2.5rem;
    align-items: end;
    padding-bottom: clamp(3rem, 7vw, 6rem);
  }

  .hero__lead {
    max-width: 46ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 2rem;
  }

  .hero__foot {
    padding-bottom: 2rem;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    justify-content: space-between;
    padding-top: 1.3rem;
  }

  @media (min-width: 900px) {
    .hero__row {
      grid-template-columns: 1fr auto;
      gap: 4rem;
    }
  }

  /* CAPÍTULO 01 */
  .intro__grid {
    display: grid;
    gap: 2.5rem;
  }

  .intro__title {
    max-width: 24ch;
    margin-bottom: 2rem;
  }

  .intro__text {
    max-width: 52ch;
    font-size: var(--step-1);
    line-height: 1.6;
  }

  @media (min-width: 900px) {
    .intro__grid {
      grid-template-columns: 1fr 3fr;
      gap: 2rem;
    }
    .intro__text {
      margin-left: auto;
      margin-right: clamp(0rem, 8vw, 6rem);
    }
  }

  /* SEGMENTOS */
  .segments {
    padding-top: 0;
  }

  .segments__header {
    display: grid;
    gap: 1.2rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .segments__list {
    border-top: 1px solid var(--line);
  }

  .segment {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1.6rem 2.2rem;
    padding: clamp(1.8rem, 4vw, 3rem) 0;
    border-bottom: 1px solid var(--line);
  }

  .segment__index {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink-3);
    align-self: start;
    padding-top: 0.7em;
  }

  .segment__title {
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    font-weight: 360;
    line-height: 1.05;
    transition: transform 0.6s var(--ease);
  }

  .segment__desc {
    max-width: 44ch;
    margin-top: 0.8rem;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .segment__media {
    display: none;
    width: clamp(120px, 13vw, 170px);
    aspect-ratio: 1;
    background: var(--stone);
    padding: 1.2rem;
    opacity: 0.55;
    filter: saturate(0.85);
    transition:
      opacity 0.6s var(--ease),
      filter 0.6s var(--ease),
      transform 0.7s var(--ease);
  }

  .segment__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .segment__cue {
    display: none;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    transition: color 0.4s var(--ease);
  }

  .segment:hover .segment__title {
    transform: translateX(0.35em);
    font-style: italic;
  }

  .segment:hover .segment__media {
    opacity: 1;
    filter: none;
    transform: translateY(-4px);
  }

  .segment:hover .segment__cue {
    color: var(--ink);
  }

  @media (min-width: 800px) {
    .segment {
      grid-template-columns: auto 1fr auto auto;
    }
    .segment__media {
      display: block;
    }
    .segment__cue {
      display: inline-block;
    }
  }

  /* FATOS */
  .facts {
    border-block: 1px solid var(--line);
  }

  .facts__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 2rem;
  }

  .fact__num {
    font-family: var(--font-serif);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 340;
    line-height: 1;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .fact__label {
    margin-top: 0.9rem;
    max-width: 22ch;
    font-size: 0.85rem;
    line-height: 1.55;
  }

  @media (min-width: 820px) {
    .facts__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* O COMPROMISSO */
  .manifesto__grid {
    display: grid;
    gap: 3.5rem;
  }

  .manifesto__intro .meta {
    margin-bottom: 1.4rem;
  }

  .manifesto__list {
    list-style: none;
    display: grid;
  }

  .manifesto__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--line-inv);
  }

  .manifesto__item:last-child {
    border-bottom: 1px solid var(--line-inv);
  }

  .manifesto__num {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ivory-3);
    padding-top: 0.5em;
  }

  .manifesto__title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .manifesto__text {
    color: var(--ivory-2);
    max-width: 52ch;
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (min-width: 900px) {
    .manifesto__grid {
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
    }
  }

  /* SELEÇÃO */
  .featured__header {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2rem;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .featured__header .meta {
    display: block;
    margin-bottom: 1.2rem;
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  @media (min-width: 900px) {
    .featured__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* CONVITE */
  .invite {
    border-top: 1px solid var(--line);
    text-align: center;
  }

  .invite__inner {
    display: grid;
    justify-items: center;
    gap: 2rem;
  }

  .invite__title {
    max-width: 18ch;
  }
</style>
