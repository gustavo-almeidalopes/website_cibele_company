---
import BaseLayout from '../layouts/BaseLayout.astro';
import { collections, stats } from '../data/catalog';

// Produto em destaque do hero — o produto acompanhado de um significado,
// nunca o item isolado. É o único momento da home que exibe um produto.
const hero = {
  eyebrow: 'Coleção Bioplástico',
  caption:
    'Louça que veste a mesa com a leveza de quem devolve à terra tudo o que dela tomou. O requinte do descartável, sem a herança fóssil.',
  cta: 'Descobrir embalagens',
  href: '/embalagens',
};
---

<BaseLayout active="home">
  <!-- HERO — produto em destaque com significado -->
  <section class="hero" data-hero>
    <div class="hero__panel">
      <div class="hero__panel-inner">
        <p class="eyebrow" data-hero-item>{hero.eyebrow} · 2026</p>
        <h1 class="display hero__title">
          <span class="line-mask"><span class="line-inner">A elegância</span></span>
          <span class="line-mask"><span class="line-inner">de um material</span></span>
          <span class="line-mask"><span class="line-inner">que <span class="text-accent">retorna</span>.</span></span>
        </h1>
        <div class="hero__foot" data-hero-item>
          <p class="hero__caption">{hero.caption}</p>
          <a class="link-arrow link-arrow--light" href={hero.href}>
            <span>{hero.cta}</span>
            <span class="arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </div>
    <div class="hero__media">
      <div class="media-ph"><span class="media-ph__label">Imagem do produto</span></div>
      <span class="hero__caption-media">Louça · Bioplástico</span>
    </div>
  </section>

  <!-- NÚMEROS (prova social) -->
  <section class="section-sm stats">
    <div class="container">
      <div class="stats__grid">
        {
          stats.map((stat) => (
            <div class="stat" data-reveal="up">
              <div class="stat__num">
                {stat.prefixo}
                <span data-count={stat.valor}>0</span>
                {stat.sufixo}
              </div>
              <p class="stat__label text-muted">{stat.rotulo}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- INTRO / STATEMENT -->
  <section class="section statement">
    <div class="container">
      <p class="eyebrow" data-reveal="fade">(A casa)</p>
      <h2 class="statement__title" data-lines>
        <span class="line-mask"><span class="line-inner">Trocamos o plástico fóssil</span></span>
        <span class="line-mask"><span class="line-inner">por materiais de origem</span></span>
        <span class="line-mask"><span class="line-inner"><span class="text-accent">renovável</span> — sem abrir</span></span>
        <span class="line-mask"><span class="line-inner">mão de resistência.</span></span>
      </h2>
      <a class="link-arrow statement__link" href="/sobre" data-reveal="fade">
        <span>Conhecer a Cibele Plastic</span>
        <span class="arrow" aria-hidden="true">↗</span>
      </a>
    </div>
  </section>

  <!-- UNIVERSOS / CATEGORIAS -->
  <section class="section showcase" id="segmentos">
    <div class="container">
      <header class="showcase__head">
        <p class="eyebrow" data-reveal="fade">As coleções</p>
        <h2 class="h-xl" data-lines>
          <span class="line-mask"><span class="line-inner">Coleções</span></span>
        </h2>
      </header>

      <div class="showcase__grid" data-reveal-group>
        {
          collections.map((col) => (
            <a class="tile" href={col.path} data-reveal-item>
              <div class="tile__media">
                <div class="media-ph">
                  <span class="media-ph__label">{col.titulo}</span>
                </div>
                <span class="tile__index">{col.indice}</span>
              </div>
              <div class="tile__body">
                <h3 class="tile__title">{col.titulo}</h3>
                <p class="tile__desc">{col.resumo}</p>
                <span class="link-arrow tile__link">
                  <span>Explorar</span>
                  <span class="arrow" aria-hidden="true">↗</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- APLICAÇÕES -->
  <section class="section-sm apps">
    <div class="container">
      <header class="apps__head">
        <p class="eyebrow" data-reveal="fade">Onde entram</p>
        <h2 class="h-lg apps__title" data-lines>
          <span class="line-mask"><span class="line-inner">Feitas para o</span></span>
          <span class="line-mask"><span class="line-inner">ritmo do seu <span class="text-accent">negócio</span>.</span></span>
        </h2>
      </header>
      <ul class="apps__list" data-reveal-group>
        {
          [
            'Food service',
            'Eventos & buffet',
            'Cafeterias & bares',
            'Delivery & take-away',
            'Hotelaria',
            'Varejo & mercados',
          ].map((item, i) => (
            <li class="apps__item" data-reveal-item>
              <span class="apps__num">{String(i + 1).padStart(2, '0')}</span>
              <span class="apps__name">{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- EDITORIAL / COMPROMISSO -->
  <section class="section-lg paper editorial">
    <div class="container editorial__grid">
      <div class="editorial__media" data-reveal="fade">
        <div class="media-ph"><span class="media-ph__label">Imagem</span></div>
      </div>
      <div class="editorial__content">
        <p class="eyebrow" data-reveal="fade">O compromisso</p>
        <h2 class="h-lg editorial__title" data-lines>
          <span class="line-mask"><span class="line-inner">Menos resíduo.</span></span>
          <span class="line-mask"><span class="line-inner">Mais <span class="text-accent">futuro</span>.</span></span>
        </h2>
        <ul class="editorial__list">
          {
            [
              {
                t: 'Matéria-prima renovável',
                d: 'Bioplásticos derivados de fontes vegetais, reduzindo a dependência do petróleo.',
              },
              {
                t: 'Decomposição acelerada',
                d: 'Produtos que voltam à natureza em uma fração do tempo do plástico comum.',
              },
              {
                t: 'Desempenho de verdade',
                d: 'Resistência e segurança comprovadas para o uso diário, na obra e na saúde.',
              },
              {
                t: 'Cadeia consciente',
                d: 'Processos pensados para gerar menos emissão de CO₂ em cada etapa.',
              },
            ].map((item, i) => (
              <li class="editorial__item" data-reveal="up">
                <span class="editorial__num">0{i + 1}</span>
                <div>
                  <h3 class="editorial__item-title">{item.t}</h3>
                  <p>{item.d}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-lg cta">
    <div class="container cta__inner">
      <p class="eyebrow" data-reveal="fade">Vamos juntos</p>
      <h2 class="display cta__title" data-lines>
        <span class="line-mask"><span class="line-inner">Construa um futuro</span></span>
        <span class="line-mask"><span class="line-inner">mais <span class="text-accent">limpo</span>.</span></span>
      </h2>
      <div class="cta__actions" data-reveal="up">
        <a class="btn btn--primary" href="/contato">
          <span>Solicitar orçamento</span>
          <svg class="arrow" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </a>
        <a class="btn btn--secondary" href="/sobre">
          <span>Conhecer a equipe</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     HERO — painel editorial + produto em destaque
     ============================================================ */
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    grid-template-rows: auto auto;
  }

  .hero__panel {
    background: var(--forest);
    color: var(--cream);
    display: flex;
  }

  .hero__panel-inner {
    width: 100%;
    padding: 7.5rem var(--gutter) 3.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.2rem;
  }

  .hero .eyebrow {
    color: var(--muted-light);
  }

  .hero__title {
    font-size: clamp(2.6rem, 11vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .hero__foot {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    max-width: 42ch;
  }

  .hero__caption {
    color: var(--muted-light);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .hero__media {
    position: relative;
    min-height: 48svh;
    background: var(--ink-2);
    overflow: hidden;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__caption-media {
    position: absolute;
    left: var(--gutter);
    bottom: 1.6rem;
    padding: 0.5rem 0.9rem;
    background: color-mix(in srgb, var(--forest) 78%, transparent);
    backdrop-filter: blur(6px);
    color: var(--cream);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-rows: none;
      grid-template-columns: 0.92fr 1.08fr;
    }
    .hero__media {
      min-height: 100svh;
    }
    .hero__panel-inner {
      padding-block: 3.5rem;
      max-width: 42rem;
      margin-left: auto;
    }
  }

  /* ============================================================
     STATEMENT — declaração editorial
     ============================================================ */
  .statement__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-4);
    line-height: 1.08;
    letter-spacing: -0.025em;
    max-width: 20ch;
    margin: var(--space-32) 0 2.4rem;
  }

  /* ============================================================
     SHOWCASE — grandes tiles de categoria
     ============================================================ */
  .showcase__head {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    justify-content: space-between;
    align-items: end;
    margin-bottom: 3rem;
  }

  .showcase__grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: 1fr;
  }

  .tile {
    position: relative;
    display: block;
    isolation: isolate;
  }

  .tile__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--ink-2);
    border-radius: var(--radius);
  }

  .tile__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease);
  }

  .tile:hover .tile__media img {
    transform: scale(1.03);
  }

  .tile__index {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    padding: 0.3rem 0.65rem;
    border-radius: var(--radius-pill);
    background: var(--cream);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .tile__body {
    padding: 1.4rem 0.2rem 0;
    display: grid;
    gap: 0.5rem;
  }

  .tile__title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .tile__desc {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
    max-width: 40ch;
  }

  .tile__link {
    margin-top: 0.6rem;
    font-size: 0.8rem;
  }

  @media (min-width: 720px) {
    .showcase__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.6rem;
    }
    .tile__media {
      aspect-ratio: 3 / 4;
    }
  }

  /* ============================================================
     APLICAÇÕES — onde as embalagens entram
     ============================================================ */
  .apps__head {
    display: grid;
    gap: var(--space-32);
    margin-bottom: 2.4rem;
  }

  .apps__title {
    max-width: 20ch;
  }

  .apps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }

  .apps__item {
    display: flex;
    align-items: baseline;
    gap: 1.2rem;
    padding: 1.3rem 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left var(--duration-slow) var(--ease), color var(--duration) var(--ease);
  }

  .apps__num {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--muted);
  }

  .apps__name {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 3.5vw, 1.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .apps__item:hover {
    padding-left: 0.7rem;
    color: var(--accent-ink);
  }

  @media (min-width: 760px) {
    .apps__list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      column-gap: 3rem;
    }
    .apps__item {
      border-bottom: 1px solid var(--line);
    }
  }

  /* ============================================================
     EDITORIAL / COMPROMISSO — imagem + valores
     ============================================================ */
  .editorial__grid {
    display: grid;
    gap: 2.6rem;
  }

  .editorial__media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius);
  }

  .editorial__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .editorial__title {
    margin: 1.4rem 0 2rem;
  }

  .editorial__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  .editorial__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--line-dark);
  }

  .editorial__item:last-child {
    border-bottom: 1px solid var(--line-dark);
  }

  .editorial__num {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent-premium);
  }

  .editorial__item-title {
    font-size: 1.12rem;
    font-weight: 700;
    margin-bottom: 0.35rem;
  }

  .editorial__item p {
    color: var(--muted-light);
    max-width: 46ch;
    font-size: 0.92rem;
    line-height: 1.55;
  }

  @media (min-width: 900px) {
    .editorial__grid {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 4.5rem;
    }
    .editorial__media {
      aspect-ratio: 3 / 4;
    }
  }

  /* ============================================================
     NÚMEROS
     ============================================================ */
  .stats {
    border-block: 1px solid var(--line);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.5rem 1rem;
  }

  .stat__num {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--bone);
  }

  .stat__label {
    margin-top: 0.7rem;
    max-width: 22ch;
    font-size: 0.84rem;
  }

  @media (min-width: 820px) {
    .stats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* ============================================================
     CTA
     ============================================================ */
  .cta {
    text-align: center;
  }

  .cta__inner {
    display: grid;
    justify-items: center;
    gap: 1.8rem;
  }

  .cta__title {
    font-size: var(--step-5);
    max-width: 14ch;
  }

  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 0.8rem;
  }
</style>
