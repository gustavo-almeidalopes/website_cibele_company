---
import { collections } from '../data/catalog';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

const isProductActive = active === 'embalagens';
---

<div class="promo-bar">
  <p class="promo-bar__inner container">Catálogo 2026 · Bioplástico para food service, eventos e delivery</p>
</div>

<header class="header" data-header>
  <div class="header__inner container">
    <a class="brand" href="/" aria-label="Cibele Plastic — página inicial">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__text">Cibele<span class="brand__accent">Plastic</span></span>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <div class="nav__item" data-mega-wrap>
        <button
          class:list={['nav__link', 'nav__trigger', { 'is-active': isProductActive }]}
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="mega-produtos"
          data-mega-toggle
        >
          <span>Coleções</span>
          <svg class="nav__chevron" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <div class="mega" id="mega-produtos" data-mega-panel hidden>
          <div class="mega__inner container">
            <div class="mega__grid">
              {
                collections.map((col) => (
                  <a class="mega__item" href={col.path} data-mega-link>
                    <span class="mega__index">{col.indice}</span>
                    <span class="mega__title">{col.titulo}</span>
                    <span class="mega__desc">{col.resumo}</span>
                    <span class="mega__cue">Ver coleção <span class="arrow">↗</span></span>
                  </a>
                ))
              }
            </div>
            <a class="mega__all link-arrow" href="/embalagens" data-mega-link>
              <span>Ver catálogo completo</span>
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>

      <a class:list={['nav__link', { 'is-active': active === 'sobre' }]} href="/sobre">
        <span>Sobre</span>
      </a>
      <a class:list={['nav__link', { 'is-active': active === 'contato' }]} href="/contato">
        <span>Contato</span>
      </a>
    </nav>

    <div class="header__search" data-search-wrap>
      <button class="icon-btn" type="button" data-search-toggle aria-expanded="false" aria-controls="header-search-form" aria-label="Buscar produtos">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="M21 21l-4.3-4.3"></path>
        </svg>
      </button>
      <form class="search-panel" id="header-search-form" data-search-panel hidden action="/embalagens" method="get">
        <input
          class="search-panel__input"
          type="search"
          name="busca"
          placeholder="Buscar por prato, copo, marmita…"
          aria-label="Buscar produtos"
          data-search-input
        />
        <button class="search-panel__submit icon-btn" type="submit" aria-label="Buscar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </button>
      </form>
    </div>

    <div class="header__actions">
      <a class="icon-btn icon-btn--wishlist" href="/favoritos" aria-label="Favoritos">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 20.5s-7.5-4.6-10-9.3C.5 8 1.8 4.5 5.2 3.6c2.1-.6 4.2.3 5.4 2 .4.5.5.7 1.4 2 .9-1.3 1-1.5 1.4-2 1.2-1.7 3.3-2.6 5.4-2 3.4.9 4.7 4.4 3.2 7.6-2.5 4.7-10 9.3-10 9.3z"></path>
        </svg>
        <span class="icon-btn__badge" data-badge="wishlist">0</span>
      </a>
      <a class="icon-btn" href="/sacola" aria-label="Sacola">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 8h12l-1 12.5a1 1 0 0 1-1 .9H8a1 1 0 0 1-1-.9L6 8Z"></path>
          <path d="M9 8V6a3 3 0 0 1 6 0v2"></path>
        </svg>
        <span class="icon-btn__badge" data-badge="cart">0</span>
      </a>
      <button class="burger" type="button" data-menu-toggle aria-expanded="false" aria-controls="menu-mobile" aria-label="Abrir menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="menu" id="menu-mobile" data-menu hidden>
  <nav class="menu__nav" aria-label="Navegação mobile">
    <a
      class:list={['menu__link', { 'is-active': active === 'embalagens' }]}
      href="/embalagens"
      data-menu-link
    >
      <span class="menu__index">01</span>
      <span class="menu__label">Embalagens</span>
    </a>
    <p class="menu__group-label eyebrow" data-menu-link>Coleções</p>
    {
      collections.map((col, index) => (
        <a class="menu__link menu__link--sub" href={col.path} data-menu-link>
          <span class="menu__index">0{index + 1}</span>
          <span class="menu__label">{col.titulo}</span>
        </a>
      ))
    }

    <a class:list={['menu__link', { 'is-active': active === 'sobre' }]} href="/sobre" data-menu-link>
      <span class="menu__index">02</span>
      <span class="menu__label">Sobre</span>
    </a>
    <a class:list={['menu__link', { 'is-active': active === 'contato' }]} href="/contato" data-menu-link>
      <span class="menu__index">03</span>
      <span class="menu__label">Contato</span>
    </a>
    <a class:list={['menu__link', { 'is-active': active === 'favoritos' }]} href="/favoritos" data-menu-link>
      <span class="menu__index">04</span>
      <span class="menu__label">Favoritos</span>
    </a>
  </nav>
  <div class="menu__foot" data-menu-link>
    <p class="eyebrow">Cibele Plastic</p>
    <p class="text-muted">Bioplástico sustentável para embalagens, construção e saúde.</p>
  </div>
</div>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    display: flex;
    align-items: center;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    transition: box-shadow var(--duration-slow) var(--ease);
  }

  .header.is-scrolled {
    box-shadow: var(--shadow-sm);
  }

  .header__inner {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--bone);
    margin-right: 0.4rem;
  }

  .brand__mark {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--forest);
  }

  .brand__accent {
    color: var(--muted);
    font-weight: 500;
  }

  .nav {
    display: none;
    align-items: center;
    gap: 0.1rem;
  }

  .nav__item {
    position: static;
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 40px;
    padding: 0.5rem 0.8rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 0;
    background: transparent;
    font-family: inherit;
    transition: color var(--duration) var(--ease);
  }

  .nav__trigger {
    cursor: pointer;
  }

  .nav__chevron {
    transition: transform var(--duration) var(--ease);
  }

  .nav__trigger.is-open .nav__chevron {
    transform: rotate(180deg);
  }

  .nav__link:hover,
  .nav__trigger.is-open,
  .nav__link.is-active {
    color: var(--bone);
  }

  /* Mega menu — painel de categorias, ancorado ao header. */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    box-shadow: var(--shadow-md);
  }

  .mega[hidden] {
    display: none;
  }

  .mega__inner {
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .mega__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .mega__item {
    position: relative;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.6rem;
    padding: 1.8rem 1.6rem;
    background: var(--cream);
    transition: background-color var(--duration) var(--ease);
  }

  .mega__item:hover {
    background: var(--ink-2);
  }

  .mega__index {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .mega__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--bone);
  }

  .mega__desc {
    font-size: 0.86rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 32ch;
  }

  .mega__cue {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 0.4rem;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--accent-ink);
  }

  .mega__cue .arrow {
    transition: transform var(--duration) var(--ease);
  }

  .mega__item:hover .mega__cue .arrow {
    transform: translate(3px, -3px);
  }

  .mega__all {
    margin-top: 1.6rem;
  }

  /* Busca */
  .header__search {
    position: relative;
    margin-left: auto;
  }

  .search-panel {
    position: absolute;
    top: calc(100% + 0.6rem);
    right: 0;
    z-index: 90;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    width: min(88vw, 360px);
    padding: 0.5rem;
    background: var(--cream);
    border: 1px solid var(--line-strong);
    box-shadow: var(--shadow-md);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity var(--duration) var(--ease), transform var(--duration) var(--ease);
  }

  .search-panel[hidden] {
    display: none;
  }

  .search-panel.is-visible {
    opacity: 1;
    transform: none;
  }

  .search-panel__input {
    flex: 1;
    min-width: 0;
    min-height: 40px;
    padding: 0.5rem 0.7rem;
    border: 0;
    background: transparent;
    color: var(--bone);
    font-family: inherit;
    font-size: 0.9rem;
  }

  .search-panel__input:focus-visible {
    outline: none;
  }

  .search-panel__submit {
    flex-shrink: 0;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .burger {
    position: relative;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 0;
    background: transparent;
    display: grid;
    place-items: center;
    transition: background-color var(--duration) var(--ease);
  }

  .burger:hover {
    background: var(--ink-2);
  }

  .burger span {
    display: block;
    width: 16px;
    height: 1.4px;
    background: var(--bone);
    transition: transform var(--duration) var(--ease), opacity var(--duration-fast) var(--ease);
  }

  .burger span + span {
    margin-top: 4px;
  }

  :global(body.menu-open) .burger span:first-child {
    transform: translateY(2.7px) rotate(45deg);
  }

  :global(body.menu-open) .burger span:last-child {
    transform: translateY(-2.7px) rotate(-45deg);
  }

  :global(html.menu-open),
  :global(body.menu-open) {
    overflow: hidden;
    height: 100%;
  }

  /* Menu overlay mobile — fundo claro, tipografia editorial grande */
  .menu {
    position: fixed;
    inset: 0;
    z-index: 95;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.2rem;
    padding: 6rem var(--gutter) 3rem;
    background: var(--cream);
    color: var(--bone);
    overflow-y: auto;
  }

  .menu[hidden] {
    display: none;
  }

  .menu__nav {
    display: flex;
    flex-direction: column;
  }

  .menu__group-label {
    margin-top: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .menu__link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    min-height: 44px;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 10vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--bone);
    opacity: 0.7;
    transition: opacity var(--duration) var(--ease), padding-left var(--duration) var(--ease);
  }

  .menu__link--sub {
    font-size: clamp(1.3rem, 6vw, 1.8rem);
    padding-left: 0.6rem;
  }

  .menu__link:hover,
  .menu__link.is-active {
    opacity: 1;
    padding-left: 0.6rem;
  }

  .menu__link--sub:hover,
  .menu__link--sub.is-active {
    padding-left: 1.1rem;
  }

  .menu__index {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
  }

  .menu__foot {
    max-width: 30ch;
  }

  .icon-btn--wishlist {
    display: none;
  }

  @media (min-width: 940px) {
    .nav {
      display: flex;
    }
    .icon-btn--wishlist {
      display: inline-flex;
    }
    .burger {
      display: none;
    }
    .menu {
      display: none !important;
    }
  }

  @media (max-width: 939.98px) {
    .mega {
      display: none !important;
    }
  }
</style>
