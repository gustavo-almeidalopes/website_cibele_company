---
import { categories } from '../data/catalog';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

const isProductActive = ['embalagens', 'construcao', 'medicos'].includes(active);
---

<header class="header" data-header>
  <div class="header__inner container-wide">
    <a class="brand" href="/" aria-label="Cibele Plastic — página inicial">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__text">Cibele<span class="brand__accent">Plastic</span></span>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <div class="nav__item" data-mega-wrap>
        <button
          class:list={['nav__link', 'nav__trigger', { 'is-active': isProductActive }]}
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="mega-produtos"
          data-mega-toggle
        >
          <span>Produtos</span>
          <svg class="nav__chevron" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <div class="mega" id="mega-produtos" data-mega-panel hidden>
          <div class="mega__inner container-wide">
            <div class="mega__grid">
              {
                categories.map((cat) => (
                  <a class="mega__item" href={cat.path} data-mega-link>
                    <span class="mega__index">{cat.indice}</span>
                    <span class="mega__title">{cat.titulo}</span>
                    <span class="mega__desc">{cat.resumo}</span>
                    <span class="mega__cue">Ver segmento <span class="arrow">↗</span></span>
                  </a>
                ))
              }
            </div>
            <a class="mega__all" href="/embalagens" data-mega-link>
              <span>Ver catálogo completo</span>
              <span class="arrow">↗</span>
            </a>
          </div>
        </div>
      </div>

      <a class:list={['nav__link', { 'is-active': active === 'sobre' }]} href="/sobre">
        <span>Sobre</span>
      </a>
    </nav>

    <div class="header__actions">
      <a class="header__cta" href="/contato" data-magnetic="0.35">
        <span>Orçamento</span>
        <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <button class="burger" type="button" data-menu-toggle aria-expanded="false" aria-controls="menu-mobile" aria-label="Abrir menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="menu" id="menu-mobile" data-menu hidden>
  <nav class="menu__nav" aria-label="Navegação mobile">
    <p class="menu__group-label eyebrow" data-menu-link>Produtos</p>
    {
      categories.map((cat, index) => (
        <a
          class:list={['menu__link', 'menu__link--sub', { 'is-active': active === cat.slug }]}
          href={cat.path}
          data-menu-link
        >
          <span class="menu__index">0{index + 1}</span>
          <span class="menu__label">{cat.titulo}</span>
        </a>
      ))
    }

    <a class:list={['menu__link', { 'is-active': active === 'sobre' }]} href="/sobre" data-menu-link>
      <span class="menu__index">04</span>
      <span class="menu__label">Sobre</span>
    </a>
    <a class:list={['menu__link', { 'is-active': active === 'contato' }]} href="/contato" data-menu-link>
      <span class="menu__index">05</span>
      <span class="menu__label">Contato</span>
    </a>
  </nav>
  <div class="menu__foot" data-menu-link>
    <p class="eyebrow">Cibele Plastic</p>
    <p>Bioplástico sustentável para embalagens, construção e saúde.</p>
  </div>
</div>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    padding-block: 1.6rem;
    transition: transform 0.5s var(--ease), background-color 0.4s var(--ease),
      backdrop-filter 0.4s var(--ease), border-color 0.4s var(--ease), padding 0.4s var(--ease);
    border-bottom: 1px solid transparent;
  }

  .header.is-scrolled {
    padding-block: 1rem;
    background: rgba(255, 255, 227, 0.88);
    backdrop-filter: blur(14px);
    border-bottom-color: var(--line);
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .brand__mark {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
  }

  .brand__accent {
    color: var(--accent);
  }

  .nav {
    display: none;
    align-items: center;
    gap: 0.35rem;
  }

  .nav__item {
    position: static;
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--muted);
    border-radius: 999px;
    border: 0;
    background: transparent;
    font-family: inherit;
    transition: color 0.3s var(--ease);
    overflow: visible;
  }

  .nav__trigger {
    cursor: pointer;
  }

  .nav__chevron {
    transition: transform 0.35s var(--ease);
  }

  .nav__trigger.is-open .nav__chevron {
    transform: rotate(180deg);
  }

  .nav__link span:first-child {
    position: relative;
    z-index: 1;
  }

  .nav__link::before {
    content: '';
    position: absolute;
    inset: auto 50% 6px;
    height: 1px;
    width: 0;
    background: var(--accent);
    transform: translateX(-50%);
    transition: width 0.4s var(--ease);
  }

  .nav__link:hover,
  .nav__trigger.is-open {
    color: var(--bone);
  }

  .nav__link:hover::before,
  .nav__link.is-active::before,
  .nav__trigger.is-open::before {
    width: calc(100% - 1.7rem);
  }

  .nav__link.is-active {
    color: var(--bone);
  }

  /* Mega menu — painel de categorias, estilo e-commerce de luxo.
     Ancorado a partir de .header (ancestral posicionado), então
     fica sempre logo abaixo do cabeçalho, nunca sobre ele. */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 90;
    background: rgba(255, 255, 227, 0.97);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--line);
    box-shadow: 0 30px 60px -30px rgba(23, 51, 23, 0.25);
  }

  .mega[hidden] {
    display: none;
  }

  .mega__inner {
    padding-block: clamp(2.2rem, 5vw, 3.5rem);
  }

  .mega__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 2rem;
  }

  .mega__item {
    position: relative;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.5rem;
    padding: 1.6rem 1.2rem;
    border-radius: var(--radius);
    transition: background-color 0.4s var(--ease);
  }

  .mega__item:hover {
    background: var(--ink-2);
  }

  .mega__index {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .mega__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--bone);
  }

  .mega__desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    max-width: 32ch;
  }

  .mega__cue {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .mega__cue .arrow {
    transition: transform 0.4s var(--ease);
  }

  .mega__item:hover .mega__cue .arrow {
    transform: translate(3px, -3px);
  }

  .mega__all {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    margin-top: 1.6rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--bone);
  }

  .mega__all .arrow {
    transition: transform 0.4s var(--ease);
  }

  .mega__all:hover .arrow {
    transform: translate(3px, -3px);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .header__cta {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--bone);
    transition: background-color 0.35s var(--ease), color 0.35s var(--ease), border-color 0.35s var(--ease);
  }

  .header__cta:hover {
    background: var(--forest);
    border-color: var(--forest);
    color: var(--cream);
  }

  .burger {
    position: relative;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: transparent;
    display: grid;
    place-items: center;
  }

  .burger span {
    display: block;
    width: 18px;
    height: 1.6px;
    background: var(--bone);
    transition: transform 0.35s var(--ease), opacity 0.25s var(--ease);
  }

  .burger span + span {
    margin-top: 5px;
  }

  :global(body.menu-open) .burger span:first-child {
    transform: translateY(3.3px) rotate(45deg);
  }

  :global(body.menu-open) .burger span:last-child {
    transform: translateY(-3.3px) rotate(-45deg);
  }

  /* O overlay do menu mobile usa o mesmo verde-escuro do texto do
     cabeçalho — sem isso, logo e burger ficam invisíveis por cima dele. */
  :global(body.menu-open) .burger span {
    background: var(--cream);
  }

  :global(body.menu-open) .brand,
  :global(body.menu-open) .brand__accent {
    color: var(--cream);
  }

  :global(body.menu-open) .brand__mark {
    background: var(--cream);
  }

  :global(html.menu-open),
  :global(body.menu-open) {
    overflow: hidden;
    height: 100%;
  }

  /* Menu overlay — fundo liso em verde-escuro, texto bege */
  .menu {
    position: fixed;
    inset: 0;
    z-index: 95;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.5rem;
    padding: 6rem var(--gutter) 3rem;
    background: var(--forest);
    color: var(--cream);
    overflow-y: auto;
  }

  .menu[hidden] {
    display: none;
  }

  .menu__nav {
    display: flex;
    flex-direction: column;
  }

  .menu__group-label {
    margin-top: 0.8rem;
    margin-bottom: 0.4rem;
    color: var(--muted-light);
  }

  .menu__link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line-dark);
    font-family: var(--font-display);
    font-size: clamp(2rem, 11vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--cream);
    opacity: 0.75;
    transition: opacity 0.3s var(--ease), padding-left 0.4s var(--ease);
  }

  .menu__link--sub {
    font-size: clamp(1.4rem, 7vw, 2.1rem);
    padding-left: 0.6rem;
  }

  .menu__link:hover,
  .menu__link.is-active {
    opacity: 1;
    padding-left: 0.8rem;
  }

  .menu__link--sub:hover,
  .menu__link--sub.is-active {
    padding-left: 1.4rem;
  }

  .menu__index {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted-light);
    letter-spacing: 0;
  }

  .menu__foot {
    color: var(--muted-light);
    max-width: 30ch;
  }

  .menu__foot .eyebrow {
    color: var(--muted-light);
  }

  @media (min-width: 940px) {
    .nav {
      display: flex;
    }
    .header__cta {
      display: inline-flex;
    }
    .burger {
      display: none;
    }
    .menu {
      display: none !important;
    }
  }

  @media (max-width: 939.98px) {
    .mega {
      display: none !important;
    }
  }
</style>
