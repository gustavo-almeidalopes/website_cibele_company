---
import { collections } from '../data/catalog';

interface Props {
  active?: string;
}
const { active = '' } = Astro.props;

const isProductActive = active === 'embalagens';
---

<header class="header" data-header>
  <div class="header__inner container">
    <a class="brand" href="/" aria-label="Cibele Plastic — página inicial">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__text">Cibele<span class="brand__accent">Plastic</span></span>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      <div class="nav__item" data-mega-wrap>
        <button
          class:list={['nav__link', 'nav__trigger', { 'is-active': isProductActive }]}
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="mega-produtos"
          data-mega-toggle
        >
          <span>Coleções</span>
          <svg class="nav__chevron" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true">
            <path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <div class="mega" id="mega-produtos" data-mega-panel hidden>
          <div class="mega__inner container">
            <div class="mega__grid">
              {
                collections.map((col) => (
                  <a class="mega__item" href={col.path} data-mega-link>
                    <span class="mega__index">{col.indice}</span>
                    <span class="mega__title">{col.titulo}</span>
                    <span class="mega__desc">{col.resumo}</span>
                    <span class="mega__cue">Ver coleção <span class="arrow">↗</span></span>
                  </a>
                ))
              }
            </div>
            <a class="mega__all link-arrow" href="/embalagens" data-mega-link>
              <span>Ver catálogo completo</span>
              <span class="arrow" aria-hidden="true">↗</span>
            </a>
          </div>
        </div>
      </div>

      <a class:list={['nav__link', { 'is-active': active === 'sobre' }]} href="/sobre">
        <span>Sobre</span>
      </a>
    </nav>

    <div class="header__actions">
      <a class="btn btn--primary header__cta" href="/contato">
        <span>Orçamento</span>
        <svg class="arrow" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <button class="burger" type="button" data-menu-toggle aria-expanded="false" aria-controls="menu-mobile" aria-label="Abrir menu">
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="menu" id="menu-mobile" data-menu hidden>
  <nav class="menu__nav" aria-label="Navegação mobile">
    <a
      class:list={['menu__link', { 'is-active': active === 'embalagens' }]}
      href="/embalagens"
      data-menu-link
    >
      <span class="menu__index">01</span>
      <span class="menu__label">Embalagens</span>
    </a>
    <p class="menu__group-label eyebrow" data-menu-link>Coleções</p>
    {
      collections.map((col, index) => (
        <a class="menu__link menu__link--sub" href={col.path} data-menu-link>
          <span class="menu__index">0{index + 1}</span>
          <span class="menu__label">{col.titulo}</span>
        </a>
      ))
    }

    <a class:list={['menu__link', { 'is-active': active === 'sobre' }]} href="/sobre" data-menu-link>
      <span class="menu__index">02</span>
      <span class="menu__label">Sobre</span>
    </a>
    <a class:list={['menu__link', { 'is-active': active === 'contato' }]} href="/contato" data-menu-link>
      <span class="menu__index">03</span>
      <span class="menu__label">Contato</span>
    </a>
  </nav>
  <div class="menu__foot" data-menu-link>
    <p class="eyebrow">Cibele Plastic</p>
    <p class="text-muted">Bioplástico sustentável para embalagens, construção e saúde.</p>
  </div>
</div>

<style>
  .header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: 72px;
    display: flex;
    align-items: center;
    background: color-mix(in srgb, var(--cream) 92%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
    transition: transform var(--duration-slow) var(--ease), box-shadow var(--duration-slow) var(--ease);
  }

  .header.is-scrolled {
    box-shadow: var(--shadow-sm);
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  .header__inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--bone);
  }

  .brand__mark {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--forest);
  }

  .brand__accent {
    color: var(--muted);
    font-weight: 500;
  }

  .nav {
    display: none;
    align-items: center;
    gap: 0.2rem;
  }

  .nav__item {
    position: static;
  }

  .nav__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 44px;
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border-radius: var(--radius-pill);
    border: 0;
    background: transparent;
    font-family: inherit;
    transition: color var(--duration) var(--ease);
  }

  .nav__trigger {
    cursor: pointer;
  }

  .nav__chevron {
    transition: transform var(--duration) var(--ease);
  }

  .nav__trigger.is-open .nav__chevron {
    transform: rotate(180deg);
  }

  .nav__link:hover,
  .nav__trigger.is-open,
  .nav__link.is-active {
    color: var(--bone);
  }

  /* Mega menu — painel de categorias, ancorado ao header. */
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 90;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
    box-shadow: var(--shadow-md);
  }

  .mega[hidden] {
    display: none;
  }

  .mega__inner {
    padding-block: clamp(2rem, 4vw, 3rem);
  }

  .mega__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .mega__item {
    position: relative;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.6rem;
    padding: 1.8rem 1.6rem;
    background: var(--cream);
    transition: background-color var(--duration) var(--ease);
  }

  .mega__item:hover {
    background: var(--ink-2);
  }

  .mega__index {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .mega__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--bone);
  }

  .mega__desc {
    font-size: 0.86rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 32ch;
  }

  .mega__cue {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    margin-top: 0.4rem;
    font-size: 0.74rem;
    font-weight: 600;
    color: var(--accent-ink);
  }

  .mega__cue .arrow {
    transition: transform var(--duration) var(--ease);
  }

  .mega__item:hover .mega__cue .arrow {
    transform: translate(3px, -3px);
  }

  .mega__all {
    margin-top: 1.6rem;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .header__cta {
    display: none;
    padding: 0.65rem 1.2rem;
    font-size: 0.82rem;
  }

  .burger {
    position: relative;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
    background: transparent;
    display: grid;
    place-items: center;
    transition: border-color var(--duration) var(--ease);
  }

  .burger:hover {
    border-color: var(--forest);
  }

  .burger span {
    display: block;
    width: 16px;
    height: 1.4px;
    background: var(--bone);
    transition: transform var(--duration) var(--ease), opacity var(--duration-fast) var(--ease);
  }

  .burger span + span {
    margin-top: 4px;
  }

  :global(body.menu-open) .burger span:first-child {
    transform: translateY(2.7px) rotate(45deg);
  }

  :global(body.menu-open) .burger span:last-child {
    transform: translateY(-2.7px) rotate(-45deg);
  }

  :global(html.menu-open),
  :global(body.menu-open) {
    overflow: hidden;
    height: 100%;
  }

  /* Menu overlay mobile — fundo claro, tipografia editorial grande */
  .menu {
    position: fixed;
    inset: 0;
    z-index: 95;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2.2rem;
    padding: 6rem var(--gutter) 3rem;
    background: var(--cream);
    color: var(--bone);
    overflow-y: auto;
  }

  .menu[hidden] {
    display: none;
  }

  .menu__nav {
    display: flex;
    flex-direction: column;
  }

  .menu__group-label {
    margin-top: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .menu__link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    min-height: 44px;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 10vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--bone);
    opacity: 0.7;
    transition: opacity var(--duration) var(--ease), padding-left var(--duration) var(--ease);
  }

  .menu__link--sub {
    font-size: clamp(1.3rem, 6vw, 1.8rem);
    padding-left: 0.6rem;
  }

  .menu__link:hover,
  .menu__link.is-active {
    opacity: 1;
    padding-left: 0.6rem;
  }

  .menu__link--sub:hover,
  .menu__link--sub.is-active {
    padding-left: 1.1rem;
  }

  .menu__index {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
  }

  .menu__foot {
    max-width: 30ch;
  }

  @media (min-width: 940px) {
    .nav {
      display: flex;
    }
    .header__cta {
      display: inline-flex;
    }
    .burger {
      display: none;
    }
    .menu {
      display: none !important;
    }
  }

  @media (max-width: 939.98px) {
    .mega {
      display: none !important;
    }
  }
</style>
