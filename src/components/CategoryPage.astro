---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from './ProductCard.astro';
import {
  getCategory,
  getProductsByCategory,
  formatPrice,
  categories,
  type CategorySlug,
} from '../data/catalog';

interface Props {
  slug: CategorySlug;
  active: string;
}

const { slug, active } = Astro.props;
const category = getCategory(slug);
const items = getProductsByCategory(slug);
const prices = items.map((p) => p.preco);
const priceRange = `${formatPrice(Math.min(...prices))} — ${formatPrice(Math.max(...prices))}`;
const others = categories.filter((c) => c.slug !== slug);
---

<BaseLayout
  active={active}
  title={`${category.headline} — Cibele`}
  description={category.descricao}
>
  <section class="phero">
    <div class="container">
      <p class="meta phero__index" data-reveal="fade">{category.indice} — Segmento</p>
      <h1 class="display phero__title" data-reveal>{category.headline}</h1>
      <div class="phero__meta" data-reveal>
        <p class="lead phero__desc text-muted">{category.descricao}</p>
        <dl class="phero__facts">
          <div>
            <dt class="meta">Peças</dt>
            <dd>{String(items.length).padStart(2, '0')}</dd>
          </div>
          <div>
            <dt class="meta">Faixa de preço</dt>
            <dd>{priceRange}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="section-sm catalog">
    <div class="container">
      <div class="catalog__grid" data-reveal-group>
        {items.map((product, i) => <ProductCard product={product} index={i} eager={i < 3} />)}
      </div>
    </div>
  </section>

  <section class="section-sm cross">
    <div class="container">
      <p class="meta cross__marker" data-reveal="fade">Explore também</p>
      <div class="cross__list">
        {
          others.map((cat) => (
            <a class="cross__item" href={cat.path} data-reveal>
              <span class="cross__idx" aria-hidden="true">{cat.indice}</span>
              <span class="cross__name">{cat.titulo}</span>
              <span class="cross__cue" aria-hidden="true">Ver segmento</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    padding-block: clamp(9.5rem, 16vw, 15rem) clamp(3.5rem, 6vw, 5.5rem);
  }

  .phero__index {
    display: block;
    margin-bottom: 1.8rem;
  }

  .phero__title {
    margin-bottom: clamp(2.2rem, 4vw, 3.2rem);
  }

  .phero__meta {
    display: grid;
    gap: 2.5rem;
    align-items: end;
  }

  .phero__desc {
    max-width: 50ch;
  }

  .phero__facts {
    display: flex;
    gap: 3rem;
  }

  .phero__facts dt {
    margin-bottom: 0.6rem;
  }

  .phero__facts dd {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 900px) {
    .phero__meta {
      grid-template-columns: 1fr auto;
      gap: 4rem;
    }
  }

  .catalog {
    border-top: 1px solid var(--line);
  }

  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem) clamp(1.2rem, 2.5vw, 2rem);
  }

  @media (min-width: 900px) {
    .catalog__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .cross {
    border-top: 1px solid var(--line);
  }

  .cross__marker {
    display: block;
    margin-bottom: 1.8rem;
  }

  .cross__item {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.6rem 0;
    border-top: 1px solid var(--line);
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.4rem);
    font-weight: 360;
    line-height: 1.05;
  }

  .cross__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .cross__idx {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink-3);
  }

  .cross__name {
    flex: 1;
    transition: transform 0.6s var(--ease);
  }

  .cross__cue {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    transition: color 0.4s var(--ease);
  }

  .cross__item:hover .cross__name {
    transform: translateX(0.35em);
    font-style: italic;
  }

  .cross__item:hover .cross__cue {
    color: var(--ink);
  }
</style>
