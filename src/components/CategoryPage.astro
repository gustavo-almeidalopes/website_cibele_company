---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from './ProductCard.astro';
import {
  getCategory,
  getProductsByCategory,
  formatPrice,
  categories,
  type CategorySlug,
} from '../data/catalog';

interface Props {
  slug: CategorySlug;
  active: string;
}

const { slug, active } = Astro.props;
const category = getCategory(slug);
const items = getProductsByCategory(slug);
const prices = items.map((p) => p.preco);
const priceRange = `${formatPrice(Math.min(...prices))} – ${formatPrice(Math.max(...prices))}`;
const others = categories.filter((c) => c.slug !== slug);
---

<BaseLayout
  active={active}
  title={`${category.headline} — Cibele Plastic`}
  description={category.descricao}
>
  <section class="phero" data-hero>
    <div class="container-wide">
      <p class="phero__index" data-hero-item>
        <span>{category.indice}</span> / Segmento
      </p>
      <h1 class="display phero__title">
        <span class="line-mask"><span class="line-inner">{category.headline}</span></span>
      </h1>
      <div class="phero__meta">
        <p class="lead phero__desc" data-hero-item>{category.descricao}</p>
        <dl class="phero__facts" data-hero-item>
          <div>
            <dt>Itens</dt>
            <dd>{String(items.length).padStart(2, '0')}</dd>
          </div>
          <div>
            <dt>Faixa de preço</dt>
            <dd>{priceRange}</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="section-sm catalog">
    <div class="container-wide">
      <div class="catalog__grid" data-reveal-group>
        {items.map((product, i) => <ProductCard product={product} index={i} />)}
      </div>
    </div>
  </section>

  <section class="section-sm cross">
    <div class="container-wide">
      <p class="eyebrow" data-reveal="fade">Explore também</p>
      <div class="cross__list">
        {
          others.map((cat) => (
            <a class="cross__item" href={cat.path} data-reveal="up" data-cursor>
              <span class="cross__idx">{cat.indice}</span>
              <span class="cross__name">{cat.titulo}</span>
              <span class="cross__arrow" aria-hidden="true">↗</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .phero {
    position: relative;
    padding-block: clamp(9.5rem, 16vw, 15rem) clamp(3.5rem, 6vw, 5.5rem);
  }

  .phero__index {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.6rem;
  }

  .phero__index span {
    color: var(--accent);
    font-size: 1rem;
  }

  .phero__title {
    margin-bottom: 2.5rem;
  }

  .phero__meta {
    display: grid;
    gap: 2rem;
    align-items: end;
  }

  .phero__desc {
    max-width: 52ch;
    color: var(--muted);
  }

  .phero__facts {
    display: flex;
    gap: 2.5rem;
    margin: 0;
  }

  .phero__facts dt {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.4rem;
  }

  .phero__facts dd {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--bone);
  }

  @media (min-width: 900px) {
    .phero__meta {
      grid-template-columns: 1fr auto;
    }
  }

  .catalog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.4rem;
  }

  .cross {
    border-top: 1px solid var(--line);
  }

  .cross .eyebrow {
    margin-bottom: 1.5rem;
  }

  .cross__list {
    display: grid;
    gap: 0;
  }

  .cross__item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1.4rem 0;
    border-top: 1px solid var(--line);
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    transition: padding-left 0.45s var(--ease), color 0.35s var(--ease);
  }

  .cross__item:last-child {
    border-bottom: 1px solid var(--line);
  }

  .cross__idx {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
  }

  .cross__name {
    flex: 1;
  }

  .cross__arrow {
    color: var(--muted);
    transition: transform 0.45s var(--ease), color 0.35s var(--ease);
  }

  .cross__item:hover {
    padding-left: 1rem;
    color: var(--accent);
  }

  .cross__item:hover .cross__arrow {
    color: var(--accent);
    transform: translate(6px, -6px);
  }
</style>
