---
const year = new Date().getFullYear();

// Navegação ampla, no formato de "mapa do site" (estilo Apple).
const columns = [
  {
    title: 'Segmentos',
    links: [
      { label: 'Embalagens', href: '/embalagens' },
      { label: 'Construção Civil', href: '/construcao' },
      { label: 'Produtos Médicos', href: '/produtos-medicos' },
    ],
  },
  {
    title: 'A empresa',
    links: [
      { label: 'Sobre nós', href: '/sobre' },
      { label: 'Nossa história', href: '/sobre' },
      { label: 'Sustentabilidade', href: '/sobre' },
    ],
  },
  {
    title: 'Atendimento',
    links: [
      { label: 'Fale conosco', href: '/contato' },
      { label: 'Solicitar orçamento', href: '/contato' },
      { label: 'Perguntas frequentes', href: '/contato' },
    ],
  },
  {
    title: 'Privacidade & Termos',
    links: [
      { label: 'Política de Privacidade', href: '/privacidade' },
      { label: 'Política de Cookies', href: '/privacidade#cookies' },
      { label: 'Termos de Uso', href: '/termos' },
      { label: 'Seus direitos (LGPD)', href: '/privacidade#lgpd' },
    ],
  },
];

const legalLinks = [
  { label: 'Política de Privacidade', href: '/privacidade' },
  { label: 'Política de Cookies', href: '/privacidade#cookies' },
  { label: 'Termos de Uso', href: '/termos' },
  { label: 'Mapa do site', href: '/' },
];
---

<footer class="footer">
  <div class="footer__marquee marquee" aria-hidden="true">
    <div class="marquee__group">
      {
        Array.from({ length: 4 }).map(() => (
          <span class="footer__ticker">
            Cibele Plastic <span class="footer__dot">●</span>
          </span>
        ))
      }
    </div>
    <div class="marquee__group">
      {
        Array.from({ length: 4 }).map(() => (
          <span class="footer__ticker">
            Cibele Plastic <span class="footer__dot">●</span>
          </span>
        ))
      }
    </div>
  </div>

  <div class="footer__top container-wide">
    <div class="footer__lead">
      <p class="eyebrow">Vamos conversar</p>
      <a class="footer__mail" href="mailto:contato@cibeleplastic.com" data-cursor>
        contato@cibeleplastic.com
      </a>
      <p class="text-muted footer__lead-text">
        Bioplástico sustentável para embalagens, construção e saúde. Respondemos em até um dia útil.
      </p>
    </div>

    <nav class="footer__cols" aria-label="Mapa do site">
      {
        columns.map((col) => (
          <div class="footer__col">
            <h4 class="footer__title">{col.title}</h4>
            <ul>
              {col.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>

  <!-- Rodapé legal (pós-footer) — dados da empresa e conformidade LGPD -->
  <div class="footer__legal">
    <div class="container-wide footer__legal-inner">
      <p class="footer__legal-note">
        A Cibele Plastic trata dados pessoais conforme a Lei Geral de Proteção de Dados (LGPD — Lei
        nº 13.709/2018). Para exercer seus direitos ou tirar dúvidas, fale com nosso Encarregado de
        Dados (DPO): <a href="mailto:privacidade@cibeleplastic.com">privacidade@cibeleplastic.com</a>.
      </p>

      <div class="footer__legal-bar">
        <p class="footer__copy">
          © {year} Cibele Plastic Ltda. — CNPJ 00.000.000/0001-00. Todos os direitos reservados.
        </p>
        <ul class="footer__legal-links">
          {
            legalLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
        <p class="footer__region" aria-label="Região">Brasil (Português)</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-2);
    border-top: 1px solid var(--line);
    padding-top: clamp(2rem, 5vw, 3.5rem);
  }

  .footer__marquee {
    --speed: 40s;
    padding-block: clamp(1rem, 3vw, 2rem);
    border-bottom: 1px solid var(--line);
  }

  .footer__ticker {
    display: inline-flex;
    align-items: center;
    gap: 3rem;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 8vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1px var(--muted-dark);
  }

  .footer__dot {
    color: var(--accent);
    -webkit-text-stroke: 0;
    font-size: 0.4em;
  }

  .footer__top {
    display: grid;
    gap: 3.5rem;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .footer__lead .eyebrow {
    margin-bottom: 1.2rem;
  }

  .footer__mail {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    background: linear-gradient(var(--accent), var(--accent)) no-repeat left bottom / 0 2px;
    transition: background-size 0.5s var(--ease);
    padding-bottom: 2px;
    margin-bottom: 1rem;
  }

  .footer__mail:hover {
    background-size: 100% 2px;
  }

  .footer__lead-text {
    max-width: 34ch;
    font-size: 0.92rem;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem 2rem;
  }

  .footer__title {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.1rem;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .footer__col a {
    position: relative;
    color: var(--bone);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.3s var(--ease);
  }

  .footer__col a:hover {
    color: var(--accent);
  }

  /* Rodapé legal / LGPD */
  .footer__legal {
    border-top: 1px solid var(--line);
  }

  .footer__legal-inner {
    padding-block: 1.8rem 2.2rem;
  }

  .footer__legal-note {
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 92ch;
    padding-bottom: 1.4rem;
    margin-bottom: 1.4rem;
    border-bottom: 1px solid var(--line);
  }

  .footer__legal-note a {
    color: var(--bone);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__legal-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .footer__legal-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
  }

  .footer__legal-links a {
    color: var(--muted);
    transition: color 0.3s var(--ease);
  }

  .footer__legal-links a:hover {
    color: var(--accent);
  }

  .footer__region {
    color: var(--muted-dark);
  }

  @media (min-width: 700px) {
    .footer__cols {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem 1.5rem;
    }
  }

  @media (min-width: 960px) {
    .footer__top {
      grid-template-columns: 1fr 1.6fr;
      gap: 4rem;
      align-items: start;
    }

    .footer__legal-bar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem 2rem;
    }

    .footer__legal-links {
      order: 2;
      justify-content: center;
      flex: 1;
    }

    .footer__region {
      order: 3;
    }
  }
</style>
