---
const year = new Date().getFullYear();

const segments = [
  { label: 'Embalagens', href: '/embalagens' },
  { label: 'Construção Civil', href: '/construcao' },
  { label: 'Produtos Médicos', href: '/produtos-medicos' },
];

const company = [
  { label: 'Sobre', href: '/sobre' },
  { label: 'Contato', href: '/contato' },
];
---

<footer class="footer night">
  <div class="footer__invite container">
    <p class="eyebrow">Uma conversa começa aqui</p>
    <a class="footer__mail" href="mailto:contato@cibeleplastic.com">
      contato@cibeleplastic.com
    </a>
  </div>

  <div class="container">
    <hr class="hr" />
  </div>

  <div class="footer__body container">
    <div class="footer__brand">
      <p class="footer__wordmark">Cibele</p>
      <p class="footer__tagline">
        Bioplásticos de origem vegetal.<br />
        O desempenho de sempre, sem a herança fóssil.
      </p>
    </div>

    <nav class="footer__col" aria-label="Segmentos">
      <h2 class="footer__title">Segmentos</h2>
      <ul>
        {
          segments.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Empresa">
      <h2 class="footer__title">Empresa</h2>
      <ul>
        {
          company.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer__col">
      <h2 class="footer__title">Atendimento</h2>
      <ul>
        <li>Segunda a sexta</li>
        <li>9h — 18h</li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>© {year} Cibele. Todos os direitos reservados.</p>
    <a href="/documents/cookiesphp.pdf" target="_blank" rel="noopener noreferrer">
      Política de Cookies
    </a>
  </div>
</footer>

<style>
  .footer {
    padding-top: clamp(5rem, 10vw, 9rem);
  }

  .footer__invite {
    display: grid;
    gap: 1.6rem;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .footer__mail {
    justify-self: start;
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 5.5vw, 3.6rem);
    font-weight: 340;
    line-height: 1.1;
    letter-spacing: -0.01em;
    background: linear-gradient(currentColor, currentColor) no-repeat left bottom / 0 1px;
    padding-bottom: 6px;
    transition: background-size 0.6s var(--ease);
  }

  .footer__mail:hover {
    background-size: 100% 1px;
  }

  .footer__body {
    display: grid;
    gap: 3rem 2rem;
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .footer__wordmark {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    color: var(--ivory-2);
    font-size: 0.92rem;
    line-height: 1.7;
    max-width: 34ch;
  }

  .footer__title {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ivory-3);
    margin-bottom: 1.3rem;
  }

  .footer__col ul {
    list-style: none;
    display: grid;
    gap: 0.7rem;
    color: var(--ivory-2);
    font-size: 0.92rem;
  }

  .footer__col a {
    color: var(--ivory-2);
    transition: color 0.35s var(--ease);
  }

  .footer__col a:hover {
    color: var(--ivory);
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 2rem;
    justify-content: space-between;
    align-items: center;
    padding-block: 1.9rem;
    border-top: 1px solid var(--line-inv);
    font-size: 0.78rem;
    color: var(--ivory-3);
  }

  .footer__bottom a {
    color: var(--ivory-3);
    transition: color 0.35s var(--ease);
  }

  .footer__bottom a:hover {
    color: var(--ivory);
  }

  @media (min-width: 800px) {
    .footer__body {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
    }
  }
</style>
