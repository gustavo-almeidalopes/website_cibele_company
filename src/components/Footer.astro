---
const year = new Date().getFullYear();

// Navegação ampla, no formato de "mapa do site" (estilo Apple).
const columns = [
  {
    title: 'Coleções',
    links: [
      { label: 'Mesa & Servir', href: '/embalagens?colecao=mesa' },
      { label: 'Copos & Bebidas', href: '/embalagens?colecao=bebidas' },
      { label: 'Delivery & Viagem', href: '/embalagens?colecao=delivery' },
      { label: 'Catálogo completo', href: '/embalagens' },
    ],
  },
  {
    title: 'Minha conta',
    links: [
      { label: 'Favoritos', href: '/favoritos' },
      { label: 'Sacola', href: '/sacola' },
      { label: 'Sobre nós', href: '/sobre' },
    ],
  },
  {
    title: 'Atendimento',
    links: [
      { label: 'Fale conosco', href: '/contato' },
      { label: 'Solicitar orçamento', href: '/contato' },
      { label: 'Perguntas frequentes', href: '/contato' },
    ],
  },
  {
    title: 'Privacidade & Termos',
    links: [
      { label: 'Política de Privacidade', href: '/privacidade' },
      { label: 'Política de Cookies', href: '/privacidade#cookies' },
      { label: 'Termos de Uso', href: '/termos' },
      { label: 'Seus direitos (LGPD)', href: '/privacidade#lgpd' },
    ],
  },
];

const legalLinks = [
  { label: 'Política de Privacidade', href: '/privacidade' },
  { label: 'Política de Cookies', href: '/privacidade#cookies' },
  { label: 'Termos de Uso', href: '/termos' },
  { label: 'Mapa do site', href: '/' },
];
---

<footer class="footer">
  <div class="footer__top container">
    <div class="footer__lead">
      <p class="eyebrow">Vamos conversar</p>
      <a class="footer__mail" href="mailto:contato@cibeleplastic.com">contato@cibeleplastic.com</a>
      <p class="text-muted footer__lead-text">
        Bioplástico sustentável para embalagens, construção e saúde. Respondemos em até um dia útil.
      </p>
    </div>

    <nav class="footer__cols" aria-label="Mapa do site">
      {
        columns.map((col) => (
          <div class="footer__col">
            <h4 class="footer__title">{col.title}</h4>
            <ul>
              {col.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>

  <!-- Rodapé legal (pós-footer) — dados da empresa e conformidade LGPD -->
  <div class="footer__legal">
    <div class="container footer__legal-inner">
      <p class="footer__legal-note">
        A Cibele Plastic trata dados pessoais conforme a Lei Geral de Proteção de Dados (LGPD — Lei
        nº 13.709/2018). Para exercer seus direitos, fale com o Encarregado de Dados (DPO):
        <a href="mailto:privacidade@cibeleplastic.com">privacidade@cibeleplastic.com</a>.
      </p>

      <div class="footer__legal-bar">
        <p class="footer__copy">
          © {year} Cibele Plastic Ltda. — CNPJ 00.000.000/0001-00. Todos os direitos reservados.
        </p>
        <ul class="footer__legal-links">
          {
            legalLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
        <p class="footer__region" aria-label="Região">Brasil (Português)</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-2);
    border-top: 1px solid var(--line);
  }

  .footer__top {
    display: grid;
    gap: 3rem;
    padding-block: var(--space-96);
  }

  .footer__lead .eyebrow {
    margin-bottom: 1.2rem;
  }

  .footer__mail {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 4.5vw, 2.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--bone);
    background: linear-gradient(var(--accent), var(--accent)) no-repeat left bottom / 0 2px;
    transition: background-size var(--duration-slow) var(--ease);
    padding-bottom: 2px;
    margin-bottom: 1rem;
  }

  .footer__mail:hover,
  .footer__mail:focus-visible {
    background-size: 100% 2px;
  }

  .footer__lead-text {
    max-width: 34ch;
    font-size: 0.92rem;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem 2rem;
  }

  .footer__title {
    font-family: var(--font);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.1rem;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }

  .footer__col a {
    position: relative;
    color: var(--bone);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color var(--duration) var(--ease);
  }

  .footer__col a:hover {
    color: var(--accent-ink);
  }

  /* Rodapé legal / LGPD */
  .footer__legal {
    border-top: 1px solid var(--line);
  }

  .footer__legal-inner {
    padding-block: 1.8rem 2.2rem;
  }

  .footer__legal-note {
    font-size: 0.8rem;
    line-height: 1.65;
    color: var(--muted);
    max-width: 75ch;
    padding-bottom: 1.4rem;
    margin-bottom: 1.4rem;
    border-bottom: 1px solid var(--line);
  }

  .footer__legal-note a {
    color: var(--bone);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer__legal-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .footer__legal-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.4rem;
  }

  .footer__legal-links a {
    color: var(--muted);
    transition: color var(--duration) var(--ease);
  }

  .footer__legal-links a:hover {
    color: var(--accent-ink);
  }

  .footer__region {
    color: var(--muted-dark);
  }

  @media (min-width: 700px) {
    .footer__cols {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem 1.5rem;
    }
  }

  @media (min-width: 960px) {
    .footer__top {
      grid-template-columns: 1fr 1.6fr;
      gap: 4rem;
      align-items: start;
    }

    .footer__legal-bar {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem 2rem;
    }

    .footer__legal-links {
      order: 2;
      justify-content: center;
      flex: 1;
    }

    .footer__region {
      order: 3;
    }
  }
</style>
