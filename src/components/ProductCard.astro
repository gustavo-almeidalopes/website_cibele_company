---
import { formatPrice, type Product } from '../data/catalog';

interface Props {
  product: Product;
  index?: number;
  eager?: boolean;
}

const { product, index = 0, eager = false } = Astro.props;

const categoryLabels: Record<string, string> = {
  embalagens: 'Embalagens',
  construcao: 'Construção',
  medicos: 'Médico',
};
---

<article class="card" data-reveal-item>
  <div class="card__media">
    <span class="card__index">{String(index + 1).padStart(2, '0')}</span>
    <span class="card__tag">{categoryLabels[product.categoria]}</span>
    <img
      src={`/img/${product.imagem}`}
      alt={product.nome}
      loading={eager ? 'eager' : 'lazy'}
      decoding="async"
      width="480"
      height="480"
    />
  </div>

  <div class="card__body">
    <div class="card__head">
      <h3 class="card__name">{product.nome}</h3>
      <span class="card__price">{formatPrice(product.preco)}</span>
    </div>
    <p class="card__desc">{product.descricao}</p>
    <button class="card__add" type="button" data-add data-name={product.nome} aria-label={`Adicionar ${product.nome} ao carrinho`}>
      <span class="card__add-label">Adicionar</span>
      <span class="card__add-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="16" height="16">
          <path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </span>
    </button>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--ink-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.5s var(--ease), border-color 0.5s var(--ease),
      background-color 0.5s var(--ease);
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: rgba(23, 51, 23, 0.4);
    background: var(--ink-3);
  }

  .card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: radial-gradient(circle at 50% 30%, #f1f4dc, #e3e6bf);
    overflow: hidden;
  }

  .card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14%;
    transition: transform 0.7s var(--ease);
  }

  .card:hover .card__media img {
    transform: scale(1.08) rotate(-1deg);
  }

  .card__index {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--muted);
    z-index: 2;
  }

  .card__tag {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: var(--forest);
    border: 1px solid var(--forest);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mint);
    backdrop-filter: blur(6px);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1.3rem;
    flex: 1;
  }

  .card__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .card__name {
    font-size: 1.02rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .card__price {
    flex-shrink: 0;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
  }

  .card__desc {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
    flex: 1;
  }

  .card__add {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 0.4rem;
    padding: 0.75rem 0.9rem 0.75rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: transparent;
    color: var(--bone);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background-color 0.35s var(--ease), color 0.35s var(--ease),
      border-color 0.35s var(--ease);
  }

  .card__add-icon {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--lime);
    color: var(--accent);
    transition: transform 0.4s var(--ease);
  }

  .card__add:hover {
    background: var(--lime);
    border-color: var(--lime);
    color: var(--accent);
  }

  .card__add:hover .card__add-icon {
    transform: rotate(90deg);
    background: var(--accent);
    color: var(--lime);
  }

  .card__add.is-added {
    background: var(--moss);
    border-color: var(--moss);
    color: #fff;
  }

  .card__add.is-added .card__add-icon {
    background: #fff;
    color: var(--moss);
  }
</style>
