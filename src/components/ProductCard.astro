---
import { formatPrice, type Product } from '../data/catalog';

interface Props {
  product: Product;
  index?: number;
  eager?: boolean;
}

const { product, index = 0, eager = false } = Astro.props;
---

<article class="piece" data-reveal>
  <a class="piece__link" href={`/contato?assunto=${product.categoria}`}>
    <figure class="piece__media">
      <img
        src={`/img/${product.imagem}`}
        alt={product.nome}
        loading={eager ? 'eager' : 'lazy'}
        decoding="async"
        width="480"
        height="480"
      />
    </figure>
    <div class="piece__head">
      <span class="piece__index" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
      <h3 class="piece__name">{product.nome}</h3>
      <span class="piece__price">{formatPrice(product.preco)}</span>
    </div>
    <p class="piece__desc">{product.descricao}</p>
    <span class="piece__cta">Solicitar orçamento</span>
  </a>
</article>

<style>
  .piece__link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .piece__media {
    position: relative;
    aspect-ratio: 4 / 5;
    background: var(--stone);
    overflow: hidden;
    margin-bottom: 1.4rem;
  }

  .piece__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16%;
    transition: transform 1s var(--ease);
  }

  .piece__link:hover .piece__media img {
    transform: scale(1.045);
  }

  .piece__head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: 0.9rem;
    margin-bottom: 0.55rem;
  }

  .piece__index {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--ink-3);
  }

  .piece__name {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.35;
  }

  .piece__price {
    font-size: 0.8rem;
    color: var(--ink-2);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .piece__desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--ink-2);
    max-width: 38ch;
    flex: 1;
  }

  .piece__cta {
    display: inline-block;
    margin-top: 1.1rem;
    padding-bottom: 0.3em;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    background: linear-gradient(currentColor, currentColor) no-repeat left bottom / 0 1px;
    transition: background-size 0.55s var(--ease);
    align-self: flex-start;
  }

  .piece__link:hover .piece__cta,
  .piece__link:focus-visible .piece__cta {
    background-size: 100% 1px;
  }
</style>
